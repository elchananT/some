# Active AI provider: mock | gemini | openai | ollama
NEXT_PUBLIC_AI_PROVIDER=mock

# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls on the client side.
# AI Studio automatically injects this if configured in the Secrets panel.
# You can also paste the key directly in-app via Settings → Gemini.
NEXT_PUBLIC_GEMINI_API_KEY=

# GEMINI_API_KEY: Fallback for some server-side scripts if used.
GEMINI_API_KEY=

# OpenAI BYOK — paste in-app via Settings or set here for CI/dev.
NEXT_PUBLIC_OPENAI_API_KEY=

# Ollama (local) base URL. Default is http://localhost:11434.
# To avoid CORS issues, export OLLAMA_ORIGINS="*" when starting `ollama serve`.
NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_MODEL=llama3.2

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
